{
  "buildCommand": "echo 'Rebuild NOW'",
  "env": {
    "FORCE_BUILD": "true",
    "CACHE_BUST": "2026-navy-gold"
  },
  "headers": [
    {
      "source": "/css/main.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
