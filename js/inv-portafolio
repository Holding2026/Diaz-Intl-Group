let INV_DATA = [];
let INV_LOADED = false;
let F_INV = 'todos';

async function loadInv() {
  $('inv-stats').innerHTML = '<div class="stat" style="grid-column:span 4;text-align:center;color:var(--t3)">Cargando directorio...</div>';
  const [tyData, kiiData] = await Promise.all([
    db.from('vista_contratos_vencimiento').select('*').order('inversionista', {ascending:true}),
    db.from('posiciones_kii').select('*').order('inversionista_nombre', {ascending:true})
  ]);
  const ty = tyData.data || [];
  const kii = kiiData.data || [];

  // Build consolidated investor directory
  const map = {};
  ty.forEach(c => {
    const key = c.inversionista.trim().toUpperCase();
    if(!map[key]) map[key] = {nombre: c.inversionista, tycoon:[], kii:[]};
    map[key].tycoon.push(c);
  });
  kii.forEach(p => {
    const key = p.inversionista_nombre.trim().toUpperCase();
    if(!map[key]) map[key] = {nombre: p.inversionista_nombre, tycoon:[], kii:[]};
    map[key].kii.push(p);
  });

  INV_DATA = Object.values(map).sort((a,b)=>a.nombre.localeCompare(b.nombre));
  INV_LOADED = true;

  // Stats
  const totalInv = INV_DATA.length;
  const soloTy = INV_DATA.filter(i=>i.tycoon.length>0&&i.kii.length===0).length;
  const soloKii = INV_DATA.filter(i=>i.kii.length>0&&i.tycoon.length===0).length;
  const ambos = INV_DATA.filter(i=>i.tycoon.length>0&&i.kii.length>0).length;
  const totalCapital = ty.reduce((a,c)=>a+(c.saldo_actual||0),0);

  $('inv-stats').innerHTML = `
    <div class="stat" style="border-top:2px solid var(--ac)"><div class="sl">Total inversionistas</div><div class="sv" style="color:var(--t)">${totalInv}</div><div class="sd">directorio consolidado</div></div>
    <div class="stat" style="border-top:2px solid var(--ac)"><div class="sl">Solo Tycoon</div><div class="sv" style="color:var(--t)">${soloTy}</div><div class="sd">contratos activos</div></div>
    <div class="stat" style="border-top:2px solid var(--ac)"><div class="sl">Solo KII</div><div class="sv" style="color:var(--t)">${soloKii}</div><div class="sd">posiciones KII</div></div>
    <div class="stat" style="border-top:2px solid var(--or);border-color:rgba(255,122,0,.3)"><div class="sl">En ambos</div><div class="sv" style="color:var(--or)">${ambos}</div><div class="sd">Tycoon + KII</div></div>`;
  $('inv-bdg').textContent = `${totalInv} inversionistas`;
  renderINV();
}

function renderINV() {
  const q = ($('inv-q').value||'').toLowerCase();
  const f = F.inv || 'todos';
  let data = INV_DATA.filter(i => {
    if(f==='tycoon' && i.tycoon.length===0) return false;
    if(f==='kii' && i.kii.length===0) return false;
    if(f==='ambos' && (i.tycoon.length===0||i.kii.length===0)) return false;
    if(q && !i.nombre.toLowerCase().includes(q)) return false;
    return true;
  });

  if(!data.length) {
    $('inv-body').innerHTML=`<tr><td colspan="8" style="text-align:center;color:var(--t3);padding:20px">Sin resultados</td></tr>`;
    $('inv-cards').innerHTML=''; return;
  }

  $('inv-body').innerHTML = data.map((inv, ix) => {
    const col = PAL[ix % PAL.length];
    const tyContratos = inv.tycoon.length;
    const tySaldo = inv.tycoon.reduce((a,c)=>a+(c.saldo_actual||0),0);
    const tyCapital = inv.tycoon.reduce((a,c)=>a+(c.valor_inicial||0),0);
    const kiiContratos = inv.kii.length;
    const kiiTokens = inv.kii.reduce((a,p)=>a+(p.total_tokens||0),0);
    const kiiValor = kiiTokens * 0.02;
    const totalHolding = tySaldo + kiiValor;
    const tyNums = inv.tycoon.map(c=>`<span style="font-family:"DM Mono",monospace;font-size:9px;color:${col}">${c.numero}</span>`).join(' ');
    const kiiNums = inv.kii.map(p=>`<span style="font-family:"DM Mono",monospace;font-size:9px;color:#9AD1F7">${p.contrato}</span>`).join(' ');
    return `<tr onclick="openInvPerfil('${inv.nombre.replace(/'/g,"\\'")}')">
      <td><div class="ic"><div class="iav" style="background:${col}18;color:${col};border:1px solid ${col}30">${ini(inv.nombre)}</div>
        <div><div class="inm">${inv.nombre}</div><div class="iid">${tyContratos>0?tyNums:''}${kiiContratos>0?' '+kiiNums:''}</div></div></div></td>
      <td><span style="font-size:11px">${tyContratos > 0 ? tyContratos+' contrato'+(tyContratos>1?'s':'') : '<span style="color:var(--t3)">—</span>'}</span></td>
      <td><span class="mn">${tyCapital>0?fm(tyCapital):'—'}</span></td>
      <td><span class="mn" style="color:${tySaldo>0?'#00D5B0':'var(--t3)'};font-weight:700">${tySaldo>0?fm(tySaldo):'—'}</span></td>
      <td><span style="font-size:11px">${kiiContratos>0?kiiContratos+' pos.':'<span style="color:var(--t3)">—</span>'}</span></td>
      <td><span class="mn" style="color:#9AD1F7">${kiiTokens>0?fmk(kiiTokens):'—'}</span></td>
      <td><span class="mn" style="color:#9AD1F7">${kiiValor>0?fm(kiiValor):'—'}</span></td>
      <td><span class="mn" style="font-weight:700;color:var(--t)">${fm(totalHolding)}</span></td>
      <td onclick="event.stopPropagation()">
        ${inv.tycoon.length ? inv.tycoon.map(c=>`<button onclick="editarContrato('${c.numero}')" style="font-size:9px;padding:2px 7px;border:0.5px solid var(--br);border-radius:4px;background:transparent;color:var(--t3);cursor:pointer;margin:1px" title="Editar ${c.numero}">${c.numero}</button>`).join('') : ''}
      </td>
    </tr>`;
  }).join('');

  $('inv-cards').innerHTML = data.map((inv,ix) => {
    const col = PAL[ix%PAL.length];
    const tySaldo = inv.tycoon.reduce((a,c)=>a+(c.saldo_actual||0),0);
    const kiiTokens = inv.kii.reduce((a,p)=>a+(p.total_tokens||0),0);
    return `<div class="mcard" onclick="openInvPerfil('${inv.nombre.replace(/'/g,"\\'")}')">
      <div class="mcard-hdr"><div class="ic"><div class="iav" style="background:${col}18;color:${col};border:1px solid ${col}30">${ini(inv.nombre)}</div>
        <div><div class="mcard-title">${inv.nombre}</div><div class="iid" style="color:${col}">${inv.tycoon.map(c=>c.numero).join(' ')} ${inv.kii.map(p=>p.contrato).join(' ')}</div></div></div></div>
      <div class="mcard-grid">
        <div class="mg-item"><div class="mgk">Tycoon saldo</div><div class="mgv g">${tySaldo>0?fm(tySaldo):'—'}</div></div>
        <div class="mg-item"><div class="mgk">KII valor</div><div class="mgv" style="color:#9AD1F7">${kiiTokens>0?fm(kiiTokens*0.02):'—'}</div></div>
        <div class="mg-item"><div class="mgk">Contratos Ty</div><div class="mgv">${inv.tycoon.length||'—'}</div></div>
        <div class="mg-item"><div class="mgk">Posiciones KII</div><div class="mgv">${inv.kii.length||'—'}</div></div>
      </div></div>`;
  }).join('');
}

