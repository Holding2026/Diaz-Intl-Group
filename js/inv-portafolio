      <div>
        <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:4px;text-transform:uppercase">Saldo actual</div>
        <input id="ec-saldo" type="number" value="${ct.saldo_actual||''}" style="width:100%;background:var(--sf2);border:1px solid var(--br);border-radius:7px;padding:7px 10px;color:var(--t);font-size:12px;outline:none">
      </div>
    </div>

    <div style="margin-bottom:12px">
      <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:4px;text-transform:uppercase">Observaciones</div>
      <textarea id="ec-obs" rows="3" style="width:100%;background:var(--sf2);border:1px solid var(--br);border-radius:7px;padding:8px 10px;color:var(--t);font-size:12px;outline:none;resize:vertical">${obsTexto}</textarea>
    </div>

    <div style="margin-bottom:12px">
      <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:6px;text-transform:uppercase">Adjuntos (${obsUrls.length})</div>
      <div id="ec-adjuntos-list" style="margin-bottom:8px">${adjuntosHTML}</div>
      <label style="display:flex;align-items:center;gap:8px;background:var(--sf2);border:1px dashed var(--br);border-radius:7px;padding:9px 12px;cursor:pointer"
        onmouseover="this.style.borderColor='var(--ac)'" onmouseout="this.style.borderColor='var(--br)'">
        <span style="font-size:16px">📎</span>
        <div>
          <div style="font-size:11px;color:var(--t)" id="ec-file-label">Agregar adjunto (JPG, PNG, PDF)</div>
          <div style="font-size:9px;color:var(--t3)">Se acumula junto a los anteriores</div>
        </div>
        <input type="file" id="ec-file" accept="image/*,.pdf" style="display:none" onchange="previewFile(this,'ec-file-label')">
      </label>
    </div>

    <button onclick="guardarContrato('${numero}','${ct.id}')" style="width:100%;background:var(--ac);color:#07100a;border:none;border-radius:7px;padding:9px;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:6px">
      Guardar cambios
    </button>
    <div id="ec-err" style="font-size:11px;color:var(--d);min-height:14px"></div>`;

  $('ov').classList.add('on');
}

async function guardarContrato(numero, contratoId) {
  const fecha_inicio = $('ec-fecha-inicio').value || null;
  const fecha_vencimiento = $('ec-fecha-vcto').value || null;
  const tipo_liquidacion = $('ec-tipo-liq').value;
  const estado = $('ec-estado').value;
  const valor_inicial = parseFloat($('ec-capital').value) || null;
  const saldo_actual = parseFloat($('ec-saldo').value) || null;
  const obsTexto = ($('ec-obs').value||'').trim();

  // Leer URLs existentes de la BD antes de actualizar
  const {data: ctActual} = await db.from('contratos_tycoon').select('observaciones,anotaciones').eq('id', contratoId).single();
  const {urls: urlsExistentes} = parseSoporte((ctActual && (ctActual.observaciones || ctActual.anotaciones)) || '');

  const btn = document.querySelector('#m-b button[onclick^="guardar"]');
  if(btn){ btn.textContent = 'Guardando...'; btn.disabled = true; }

  // Upload nuevo adjunto si hay
  let urlsFinales = [...urlsExistentes];
  const fileEl = $('ec-file');
  if(fileEl && fileEl.files && fileEl.files[0]) {
    const file = fileEl.files[0];
    const ts = Date.now();
    const ext = file.name.split('.').pop();
    const path = `tycoon/${numero}/contrato-${ts}.${ext}`;
    const {error: errFile} = await db.storage.from('soportes-tycoon').upload(path, file, {upsert:true});
    if(!errFile) {
      const {data: urlData} = db.storage.from('soportes-tycoon').getPublicUrl(path);
      urlsFinales.push(urlData.publicUrl);
    }
  }

  // Construir observaciones: texto + todos los [soporte:URL] acumulados
  const nuevasObs = obsTexto + urlsFinales.map(u => '[soporte:' + u + ']').join('');

  const {error} = await db.from('contratos_tycoon').update({
    fecha_inicio, fecha_vencimiento, tipo_liquidacion, estado,
    valor_inicial, saldo_actual,
    observaciones: nuevasObs
  }).eq('id', contratoId);

  if(error){
    $('ec-err').textContent = 'Error: ' + error.message;
    if(btn){ btn.textContent = 'Guardar cambios'; btn.disabled = false; }
    return;
  }
  toast('Contrato ' + numero + ' actualizado ✓', 'ok');
  closeM();
  // Refrescar datos
  TYC_DATA = [];
  INV_LOADED = false;
  await loadTycoon();
  loadInv();
}

async function eliminarAdjuntoContrato(numero, idx) {
  if(!confirm('¿Eliminar este adjunto?')) return;
  const {data: ct} = await db.from('contratos_tycoon').select('observaciones,anotaciones,id').eq('numero', numero).single();
  const {texto, urls} = parseSoporte((ct.observaciones || ct.anotaciones) || '');
  urls.splice(idx, 1);
  const nuevasObs = texto + urls.map(u => '[soporte:' + u + ']').join('');
  await db.from('contratos_tycoon').update({observaciones: nuevasObs}).eq('id', ct.id);
  toast('Adjunto eliminado', 'ok');
  editarContrato(numero);
}

