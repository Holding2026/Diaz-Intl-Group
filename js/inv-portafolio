async function guardarNuevoContrato(nextNumSugerido) {
  const invVal = $('nc-inv').value;
  if(!invVal){ $('nc-err').textContent='Selecciona un inversionista'; return; }
  const [invId, invNombre] = invVal.split('|');
  const numero = ($('nc-numero').value||'').trim().toUpperCase() || nextNumSugerido;
  const capital = parseFloat($('nc-capital').value) || 0;
  const saldo   = parseFloat($('nc-saldo').value) || capital;
  const fecha_inicio = $('nc-fecha_inicio').value || null;
  const fecha_vcto   = $('nc-fecha_vcto').value || null;
  if(!fecha_inicio || !fecha_vcto){ $('nc-err').textContent='Fechas de inicio y vencimiento son obligatorias'; return; }
  if(!capital){ $('nc-err').textContent='El capital inicial es obligatorio'; return; }

  const btn = document.querySelector('#m-b button[onclick^="guardarNuevoContrato"]');
  if(btn){ btn.textContent='Guardando...'; btn.disabled=true; }

  const payload = {
    numero,
    nombre_inversionista: invNombre,
    inversionista_id:     invId || null,
    valor_inicial:        capital,
    saldo_actual:         saldo,
    tipo_liquidacion:     $('nc-tipo').value,
    estado:               $('nc-estado').value,
    fecha_inicio,
    fecha_vencimiento:    fecha_vcto,
    observaciones:        ($('nc-obs').value||'').trim()||null
  };

  const {error} = await db.from('contratos_tycoon').insert(payload);
  if(error){
    $('nc-err').textContent = 'Error: '+error.message;
    if(btn){btn.textContent='Crear Contrato';btn.disabled=false;}
    return;
  }

  toast('Contrato '+numero+' creado para '+invNombre+' ✓','ok');
  closeM();
  await loadTycoon();
  await loadInv();
}

