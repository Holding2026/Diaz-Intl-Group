async function guardarNuevoInversionista() {
  const nombre = ($('ni-nombre').value||'').trim();
  if(!nombre) { $('ni-err').textContent = 'El nombre es obligatorio'; return; }
  const btn = document.querySelector('#m-b button[onclick="guardarNuevoInversionista()"]');
  if(btn){ btn.textContent = 'Guardando...'; btn.disabled = true; }

  // 1. Crear en tabla inversionistas (registro principal)
  const {data: invData, error: invErr} = await db.from('inversionistas')
    .insert({ nombre })
    .select('id')
    .single();
  if(invErr){ $('ni-err').textContent='Error: '+invErr.message; if(btn){btn.textContent='Crear Inversionista';btn.disabled=false;} return; }

  const invId = invData.id;

  // 2. Crear perfil extendido
  const perfil = {
    inversionista_id: invId,
    nombre_legal:     ($('ni-nombre_legal').value||'').trim()||null,
    nombre_contrato:  ($('ni-nombre_contrato').value||'').trim()||null,
    nacionalidad:     ($('ni-nacionalidad').value||'').trim()||null,
    tipo_documento:   ($('ni-tipo_doc').value||'').trim()||null,
    numero_documento: ($('ni-num_doc').value||'').trim()||null,
    fecha_nacimiento: $('ni-fecha_nac').value||null,
    vendedor:         ($('ni-vendedor').value||'').trim()||null,
    email:            ($('ni-email').value||'').trim()||null,
    email_secundario: ($('ni-email2').value||'').trim()||null,
    telefono:         ($('ni-telefono').value||'').trim()||null,
    whatsapp:         ($('ni-whatsapp').value||'').trim()||null,
    pais_residencia:  ($('ni-pais').value||'').trim()||null,
    ciudad:           ($('ni-ciudad').value||'').trim()||null,
    direccion:        ($('ni-direccion').value||'').trim()||null,
    codigo_postal:    ($('ni-cp').value||'').trim()||null,
    notas_admin:      ($('ni-notas').value||'').trim()||null,
    updated_at:       new Date().toISOString()
  };
  // Omitir campos nulos para no pisar defaults
  Object.keys(perfil).forEach(k => { if(perfil[k]===null) delete perfil[k]; });

  const {error: pErr} = await db.from('inversionistas_perfil').insert(perfil);
  if(pErr) log('warn', 'Perfil parcial:', pErr.message); // No es crítico

  toast('Inversionista "'+nombre+'" creado ✓', 'ok');
  closeM();
  await loadInv(); // Refrescar directorio
}

// ── NUEVO CONTRATO ────────────────────────────────────────────
async function openNuevoContrato() {
  // Cargar lista de inversionistas de la tabla inversionistas
  const {data: invList} = await db.from('inversionistas').select('id,nombre').order('nombre');
  const opts = (invList||[]).map(i => `<option value="${i.id}|${i.nombre}">${i.nombre}</option>`).join('');

  // Generar próximo número de contrato
  const {data: cts} = await db.from('contratos_tycoon').select('numero').order('numero');
  let nextNum = 'T1';
  if(cts && cts.length) {
    const nums = cts.map(c => parseInt((c.numero||'T0').replace(/\D/g,''))).filter(n=>!isNaN(n));
    if(nums.length) nextNum = 'T' + (Math.max(...nums)+1);
  }

  const fld = (id, label, type='text') => `<div>
    <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:4px;text-transform:uppercase">${label}</div>
    <input id="nc-${id}" type="${type}" placeholder="${label}..." style="width:100%;background:var(--sf2);border:1px solid var(--br);border-radius:7px;padding:7px 10px;color:var(--t);font-size:12px;outline:none"></div>`;

  const sel = (id, label, options) => `<div>
    <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:4px;text-transform:uppercase">${label}</div>
    <select id="nc-${id}" style="width:100%;background:var(--sf2);border:1px solid var(--br);border-radius:7px;padding:7px 10px;color:var(--t);font-size:12px;outline:none">
      ${options}
    </select></div>`;

  $('m-t').textContent = 'Nuevo Contrato Tycoon';
  $('m-s').textContent = 'El inversionista debe existir en el sistema';
  $('m-b').innerHTML = `
    <div style="background:rgba(0,169,141,0.07);border:1px solid rgba(0,169,141,0.2);border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:11px;color:#00A98D">
      Número asignado automáticamente: <strong style="font-family:"DM Mono",monospace">${nextNum}</strong>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
      ${sel('inv','Inversionista','<option value="">— Seleccionar inversionista —</option>'+opts)}
      ${fld('numero','Número contrato')}
      ${fld('fecha_inicio','Fecha inicio','date')}
      ${fld('fecha_vcto','Fecha vencimiento','date')}
      ${sel('tipo','Tipo liquidación',
        ['Trimestral','Semestral','Anual'].map(t=>`<option value="${t}">${t}</option>`).join(''))}
      ${sel('estado','Estado',
        ['Activo','On Hold','Terminado','Liquidado'].map(s=>`<option value="${s}">${s}</option>`).join(''))}
      ${fld('capital','Capital inicial (USD)','number')}
      ${fld('saldo','Saldo actual (USD)','number')}
    </div>
    <div style="margin-bottom:12px">
      <div style="font-size:9px;color:var(--t3);font-family:"DM Mono",monospace;margin-bottom:4px;text-transform:uppercase">Observaciones</div>
      <textarea id="nc-obs" rows="2" placeholder="Observaciones del contrato..." style="width:100%;background:var(--sf2);border:1px solid var(--br);border-radius:7px;padding:8px 10px;color:var(--t);font-size:12px;outline:none;resize:vertical"></textarea>
    </div>
    <button onclick="guardarNuevoContrato('${nextNum}')" style="width:100%;background:#00A98D;color:#fff;border:none;border-radius:7px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:6px">
      Crear Contrato
    </button>
    <div id="nc-err" style="font-size:11px;color:var(--d);min-height:14px"></div>`;

  // Auto-fill número con el sugerido
  $('nc-numero').value = nextNum;
